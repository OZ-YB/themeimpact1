{% doc %}
  @prompt
    Génere moi un espace avec image à insérer pour mettre les avis clients 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-customer-reviews-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-customer-reviews__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.spacing_between_elements }}px;
  }

  .ai-customer-reviews__title-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.spacing_between_elements | divided_by: 2 }}px;
  }

  .ai-customer-reviews__subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subtitle_size }}px;
    margin: 0;
  }

  .ai-customer-reviews__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.spacing_between_elements }}px;
  }

  .ai-customer-reviews__item-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.card_inner_spacing }}px;
  }

  .ai-customer-reviews__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-customer-reviews__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-customer-reviews__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-customer-reviews__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-customer-reviews__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    color: #999;
    text-align: center;
    pointer-events: none;
    background-color: rgba(255, 255, 255, 0.9);
    padding: 4px 8px;
    border-radius: 4px;
  }

  .ai-customer-reviews__rating-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    justify-content: {{ block.settings.text_alignment }};
  }

  .ai-customer-reviews__star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    color: {{ block.settings.star_color }};
  }

  .ai-customer-reviews__star-{{ ai_gen_id }}--empty {
    color: {{ block.settings.star_empty_color }};
  }

  .ai-customer-reviews__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.review_text_size }}px;
    line-height: 1.6;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-customer-reviews__author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: auto;
  }

  .ai-customer-reviews__avatar-{{ ai_gen_id }} {
    width: {{ block.settings.avatar_size }}px;
    height: {{ block.settings.avatar_size }}px;
    border-radius: 50%;
    object-fit: cover;
    background-color: {{ block.settings.avatar_background }};
    flex-shrink: 0;
  }

  .ai-customer-reviews__avatar-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.avatar_size }}px;
    height: {{ block.settings.avatar_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.avatar_background }};
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-customer-reviews__avatar-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    color: {{ block.settings.text_color }};
    opacity: 0.3;
  }

  .ai-customer-reviews__author-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ai-customer-reviews__author-name-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-weight: 600;
    font-size: {{ block.settings.author_name_size }}px;
    margin: 0;
  }

  .ai-customer-reviews__author-title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.author_title_size }}px;
    opacity: 0.7;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-customer-reviews__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<customer-reviews-{{ ai_gen_id }} class="ai-customer-reviews-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank or block.settings.subtitle != blank %}
    <div class="ai-customer-reviews__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-customer-reviews__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <div class="ai-customer-reviews__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-customer-reviews__grid-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign image_key = 'review_' | append: i | append: '_image'
        assign rating_key = 'review_' | append: i | append: '_rating'
        assign text_key = 'review_' | append: i | append: '_text'
        assign name_key = 'review_' | append: i | append: '_name'
        assign title_key = 'review_' | append: i | append: '_title'
        assign avatar_key = 'review_' | append: i | append: '_avatar'

        assign review_image = block.settings[image_key]
        assign review_rating = block.settings[rating_key]
        assign review_text = block.settings[text_key]
        assign review_name = block.settings[name_key]
        assign review_title = block.settings[title_key]
        assign review_avatar = block.settings[avatar_key]
      %}

      <div class="ai-customer-reviews__item-{{ ai_gen_id }}">
        {% if block.settings.show_images %}
          <div class="ai-customer-reviews__image-wrapper-{{ ai_gen_id }}">
            {% if review_image %}
              <img
                src="{{ review_image | image_url: width: 800 }}"
                alt="{{ review_image.alt | escape }}"
                loading="lazy"
                width="{{ review_image.width }}"
                height="{{ review_image.height }}"
                class="ai-customer-reviews__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-customer-reviews__image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                <div class="ai-customer-reviews__empty-state-{{ ai_gen_id }}">
                  Ajouter une image
                </div>
              </div>
            {% endif %}
          </div>
        {% endif %}

        {% if block.settings.show_rating %}
          <div class="ai-customer-reviews__rating-{{ ai_gen_id }}">
            {% for star in (1..5) %}
              <svg class="ai-customer-reviews__star-{{ ai_gen_id }} {% if star > review_rating %}ai-customer-reviews__star-{{ ai_gen_id }}--empty{% endif %}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {% endfor %}
          </div>
        {% endif %}

        {% if review_text != blank %}
          <div class="ai-customer-reviews__text-{{ ai_gen_id }}">{{ review_text }}</div>
        {% else %}
          <div class="ai-customer-reviews__text-{{ ai_gen_id }}" style="opacity: 0.5; font-style: italic;">Ajouter le texte de l'avis</div>
        {% endif %}

        <div class="ai-customer-reviews__author-{{ ai_gen_id }}">
          {% if review_avatar %}
            <img
              src="{{ review_avatar | image_url: width: 100 }}"
              alt="{{ review_name | escape }}"
              loading="lazy"
              class="ai-customer-reviews__avatar-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-customer-reviews__avatar-placeholder-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </div>
          {% endif %}
          <div class="ai-customer-reviews__author-info-{{ ai_gen_id }}">
            {% if review_name != blank %}
              <div class="ai-customer-reviews__author-name-{{ ai_gen_id }}">{{ review_name }}</div>
            {% else %}
              <div class="ai-customer-reviews__author-name-{{ ai_gen_id }}" style="opacity: 0.5; font-style: italic;">Nom du client</div>
            {% endif %}
            {% if review_title != blank %}
              <div class="ai-customer-reviews__author-title-{{ ai_gen_id }}">{{ review_title }}</div>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</customer-reviews-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomerReviews{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('customer-reviews-{{ ai_gen_id }}', CustomerReviews{{ ai_gen_id }});
  })();
</script>

